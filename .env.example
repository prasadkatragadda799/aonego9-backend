# development | production — production disables /docs and /redoc.
ENVIRONMENT=development

# Local dev defaults to SQLite. In production, set this to your managed
# Postgres URL — postgres:// / postgresql:// are both auto-normalized to
# the asyncpg driver, so you can paste the URL your host gives you as-is.
DATABASE_URL=sqlite+aiosqlite:///./aonego9.db

SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated list of allowed frontend origins in production, e.g.
# https://aonego9-user.vercel.app,https://aonego9-vendor.vercel.app
# Defaults to "*" (fine for local dev; tighten this in production).
CORS_ORIGINS=*
